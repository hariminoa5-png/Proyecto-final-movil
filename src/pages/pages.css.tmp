/* Photo Upload Styles */
.photo-upload-zone {
  width: 100%;
  height: 180px;
  background: rgba(255,255,255,0.03);
  border: 2px dashed rgba(255,255,255,0.1);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s;
}

.photo-upload-zone:active {
  background: rgba(255,255,255,0.05);
  border-color: var(--color-blue);
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.3);
}

.photo-placeholder ion-icon {
  font-size: 32px;
}

.photo-placeholder span {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.photo-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 24px;
}

.photo-chip {
  width: 100%;
  aspect-ratio: 1;
  background: rgba(255,255,255,0.03);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
}

.photo-chip img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Community Garage / Search Styles */
.custom-search {
  --background: rgba(255, 255, 255, 0.05);
  --color: #fff;
  --placeholder-color: rgba(255, 255, 255, 0.4);
  --icon-color: var(--color-blue);
  --clear-button-color: #fff;
  padding: 0 16px 12px;
}

.vehicle-selector {
  display: flex;
  overflow-x: auto;
  padding: 10px 20px;
  gap: 10px;
  -webkit-overflow-scrolling: touch;
}

.vehicle-selector::-webkit-scrollbar {
  display: none;
}

.v-chip {
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  white-space: nowrap;
  transition: all 0.3s;
}

.v-chip.active {
  background: var(--color-blue);
  border-color: var(--color-blue);
  box-shadow: 0 4px 15px rgba(29, 140, 248, 0.3);
}
